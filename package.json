{
  "name": "unofficial-antigravity-sdk",
  "version": "1.0.2",
  "description": "Unofficial TypeScript SDK port for Google Antigravity",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/mweinbach/antigravity-ts"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "localharness": "./dist/bin/localharness.js"
  },
  "files": [
    "dist",
    "vendor/localharness",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./connections/local": {
      "types": "./dist/connections/local/index.d.ts",
      "import": "./dist/connections/local/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "tsx scripts/clean.ts",
    "prepack": "npm run sync:localharness && npm run build",
    "sync:localharness": "tsx scripts/sync-localharness-runtimes.ts",
    "test": "node --import tsx --test tests/*.test.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.scripts.json",
    "verify-release-version": "tsx scripts/verify-release-version.ts"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chokidar": "^5.0.0",
    "js-yaml": "^4.1.1",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
