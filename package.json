{
  "name": "unofficial-antigravity-sdk",
  "version": "1.0.0",
  "description": "Unofficial TypeScript SDK port for Google Antigravity",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "localharness": "./bin/localharness.js"
  },
  "files": [
    "dist",
    "bin",
    "vendor/localharness",
    "README.md"
  ],
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "prepack": "npm run sync:localharness && npm run build",
    "sync:localharness": "node scripts/sync-localharness-runtimes.mjs",
    "test": "node --import tsx --test tests/*.test.ts"
  },
  "dependencies": {
    "@google/genai": "^2.4.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "chokidar": "^5.0.0",
    "js-yaml": "^4.1.1",
    "zod": "^4.4.3",
    "zod-to-json-schema": "^3.25.2"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.9.1",
    "tsx": "^4.22.3",
    "typescript": "^6.0.3"
  }
}
